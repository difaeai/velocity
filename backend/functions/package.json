{
  "name": "velocity-functions",
  "version": "0.1.0",
  "private": true,
  "description": "Velocity ride-hailing — secure backend (Firebase Cloud Functions, TypeScript).",
  "engines": {
    "node": "22"
  },
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "serve": "npm run build && firebase emulators:start --only functions,firestore,auth,storage",
    "deploy": "firebase deploy --only functions"
  },
  "dependencies": {
    "firebase-admin": "^13.0.2",
    "firebase-functions": "^6.3.2",
    "geofire-common": "^6.0.0",
    "ngeohash": "^0.6.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "eslint": "^9.18.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.21.0"
  }
}
