# Firebase Web config (NOT secret — the Web API key only identifies the project;
# access is enforced by Firestore rules + App Check). Override per-environment.
# All client-exposed vars MUST be prefixed EXPO_PUBLIC_ to be inlined by Expo.
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
