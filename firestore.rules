rules_version = '2';

// ============================================================================
//  Velocity — Firestore Security Rules
// ----------------------------------------------------------------------------
//  Security model (see docs/SECURITY.md):
//   * Default DENY. Nothing is accessible unless a rule below explicitly allows.
//   * Authentication is REQUIRED for every read and write.
//   * Roles are carried in custom claims (request.auth.token.role), which are
//     ONLY settable by the backend (Cloud Functions via the Admin SDK).
//   * Money, verification status, ratings, trip state and counters are
//     SERVER-AUTHORITATIVE: clients can never write them directly. Those paths
//     are written exclusively by Cloud Functions, which bypass these rules.
//   * Where clients may write at all, writes are restricted to an explicit
//     whitelist of fields so privileged fields cannot be smuggled in.
// ============================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ----- Helpers ---------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }

    function isOwner(userId) {
      return isSignedIn() && uid() == userId;
    }

    function role() {
      return isSignedIn() ? request.auth.token.role : '';
    }

    function isAdmin() {
      return role() == 'admin';
    }

    function isDriver() {
      return role() == 'driver';
    }

    // True when the incoming write only touches the supplied field names.
    function onlyChanges(allowed) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(allowed);
    }

    // ----- users/{uid} -----------------------------------------------------
    // Profile docs. Created by the onUserCreate backend trigger. The owner may
    // edit only safe profile fields; role / verification / wallet live elsewhere
    // or are server-only.
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      // Direct client creation is disabled; the backend creates the profile.
      allow create: if false;
      allow update: if isOwner(userId)
                    && onlyChanges(['displayName', 'photoURL', 'gender', 'fcmToken', 'updatedAt'])
                    && request.resource.data.gender in ['male', 'female', 'unspecified'];
      allow update: if isAdmin();
      allow delete: if false;
    }

    // ----- drivers/{uid} ---------------------------------------------------
    // Driver operational doc. Verification, rating, earnings and commission are
    // server-only. The driver may update ONLY presence/location fields so GPS
    // pings don't require a function call on every update.
    match /drivers/{driverId} {
      allow read: if isOwner(driverId) || isAdmin();
      allow create: if false;
      allow update: if isOwner(driverId)
                    && isDriver()
                    && onlyChanges(['online', 'lastLocation', 'heading', 'lastSeenAt']);
      allow update: if isAdmin();
      allow delete: if false;
    }

    // ----- trips/{tripId} --------------------------------------------------
    // Fully server-authoritative. Trips are created and mutated only by Cloud
    // Functions. Clients READ if they are a participant; they ACT via callables.
    match /trips/{tripId} {
      allow read: if isAdmin()
                  || (isSignedIn() && resource.data.passengerId == uid())
                  || (isSignedIn() && resource.data.driverId == uid());
      allow write: if false;

      // Bids placed by drivers (created server-side via placeBid). The passenger
      // who owns the parent trip and the bidding driver may read.
      match /bids/{bidId} {
        allow read: if isAdmin()
                    || (isSignedIn() && get(/databases/$(database)/documents/trips/$(tripId)).data.passengerId == uid())
                    || (isSignedIn() && resource.data.driverId == uid());
        allow write: if false;
      }

      // In-ride chat between the matched passenger and driver.
      match /chat/{msgId} {
        allow read: if isAdmin()
                    || (isSignedIn() && get(/databases/$(database)/documents/trips/$(tripId)).data.passengerId == uid())
                    || (isSignedIn() && get(/databases/$(database)/documents/trips/$(tripId)).data.driverId == uid());
        allow create: if isSignedIn()
                      && (
                        get(/databases/$(database)/documents/trips/$(tripId)).data.passengerId == uid()
                        || get(/databases/$(database)/documents/trips/$(tripId)).data.driverId == uid()
                      )
                      && request.resource.data.keys().hasAll(['senderId', 'senderName', 'text', 'sentAt'])
                      && request.resource.data.senderId == uid()
                      && request.resource.data.text is string
                      && request.resource.data.text.size() > 0
                      && request.resource.data.text.size() <= 500;
        allow update, delete: if false;
      }
    }

    // ----- poolRides/{rideId} ----------------------------------------------
    match /poolRides/{rideId} {
      allow read: if isSignedIn();
      allow create: if isDriver() && request.resource.data.driverId == uid();
      allow update: if (isDriver() && resource.data.driverId == uid())
                    || (isSignedIn()
                        && onlyChanges(['takenSeats', 'status', 'boardingStartedAt', 'updatedAt']));
      allow delete: if false;

      match /passengers/{passengerId} {
        allow read: if isSignedIn() && (uid() == passengerId || isDriver() || isAdmin());
        allow create: if isSignedIn() && uid() == passengerId;
        allow update: if isDriver() || isAdmin();
        allow delete: if false;
      }

      // Group chat for the pool ride (driver + all passengers)
      match /chat/{msgId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn()
                      && request.resource.data.keys().hasAll(['senderId', 'senderName', 'text', 'sentAt'])
                      && request.resource.data.senderId == uid()
                      && request.resource.data.text is string
                      && request.resource.data.text.size() > 0
                      && request.resource.data.text.size() <= 500;
        allow update, delete: if false;
      }
    }

    // ----- ratings/{ratingId} ----------------------------------------------
    // Written exclusively by the submitRating Cloud Function.
    match /ratings/{ratingId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.raterId == uid());
      allow write: if false;
    }

    // ----- wallets/{uid} ---------------------------------------------------
    // Balances and ledger are server-only writes. Owner and admin may read.
    match /wallets/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if false;

      match /transactions/{txId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if false;
      }
    }

    // ----- safetyEvents/{id} ----------------------------------------------
    // SOS / route-deviation records. Created server-side. The reporter and any
    // admin may read; nobody writes directly.
    match /safetyEvents/{eventId} {
      allow read: if isAdmin()
                  || (isSignedIn() && resource.data.reportedBy == uid());
      allow write: if false;
    }

    // ----- system/{doc} ----------------------------------------------------
    // Platform counters (revenue, commissions, payouts). Admin-readable for the
    // dashboard; never client-writable.
    match /system/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ----- auditLogs/{id} --------------------------------------------------
    match /auditLogs/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ----- config/{doc} ----------------------------------------------------
    // Public app configuration (ride types, base fares, service areas). Any
    // authenticated user may read; only admins may change it.
    match /config/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ----- paymentIntents/{id} & payouts/{id} -----------------------------
    // Wallet top-up intents and driver payout requests. Written only by the
    // backend; the owner and admins may read.
    match /paymentIntents/{intentId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.uid == uid());
      allow write: if false;
    }
    match /payouts/{payoutId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.driverId == uid());
      allow write: if false;
    }

    // ----- openRequests/{tripId} ------------------------------------------
    // Public-safe feed of open ride requests, written only by the backend.
    // Approved drivers (driver role) read it to discover work; the full trip
    // document stays private to its participants.
    match /openRequests/{tripId} {
      allow read: if isDriver();
      allow write: if false;
    }

    // ----- travelMatePlans/{planId} ----------------------------------------
    // Any authenticated user can browse plans (needed for the subscription
    // purchase screen). Writes go exclusively through the CF (Admin SDK).
    match /travelMatePlans/{planId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // ----- travelMateSubscriptions/{subId} ---------------------------------
    // A user may read (and list) their own subscriptions.
    // Admin reads all. All writes go through the CF.
    match /travelMateSubscriptions/{subId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.uid == uid());
      allow write: if false;
    }

    // ----- travelMateProfiles/{uid} ----------------------------------------
    // Profiles are OPAQUE to all clients. The getTravelMateFeed CF serves
    // candidates via Admin SDK so we never expose another user's home address
    // or commute details directly. All writes go through upsertTravelMateProfile.
    match /travelMateProfiles/{userId} {
      // The owner may read their own profile (to pre-fill the setup form).
      allow read: if isOwner(userId);
      allow write: if false; // CF (Admin SDK) only

      // Swipe records — the owner can read their own swipe history.
      match /swipes/{targetId} {
        allow read: if isOwner(userId);
        allow write: if false;
      }
    }

    // ----- travelMateMatches/{matchId} -------------------------------------
    // A match doc's `users` array contains exactly two sorted UIDs.
    // Only the two matched users may read the match or its chat.
    match /travelMateMatches/{matchId} {
      allow read: if isSignedIn() && uid() in resource.data.users;
      allow write: if false;

      match /chat/{msgId} {
        allow read: if isSignedIn()
                    && uid() in get(/databases/$(database)/documents/travelMateMatches/$(matchId)).data.users;
        allow create: if isSignedIn()
                      && uid() in get(/databases/$(database)/documents/travelMateMatches/$(matchId)).data.users
                      && request.resource.data.senderId == uid()
                      && request.resource.data.text is string
                      && request.resource.data.text.size() > 0
                      && request.resource.data.text.size() <= 500;
        allow update, delete: if false;
      }
    }

    // ----- travelMateQuota/{uid} -------------------------------------------
    // Like-quota docs are written only by the travelMateSwipe CF.
    // The owner may read their own quota to render the paywall UI.
    match /travelMateQuota/{userId} {
      allow read: if isOwner(userId);
      allow write: if false;
    }

    // ----- Catch-all DENY --------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
